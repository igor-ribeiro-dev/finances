generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String               @id @default(uuid())
  name                  String               @db.VarChar(100)
  email                 String               @unique @db.VarChar(255)
  passwordHash          String               @db.VarChar(255)
  familyGroupId         String?
  familyGroup           FamilyGroup?         @relation(fields: [familyGroupId], references: [id])
  sessions              Session[]
  resetTokens           PasswordResetToken[]
  idempotencyKeys       IdempotencyKey[]
  memberBudgets         Budget[]             @relation("MemberBudget")
  billsOwned            Bill[]               @relation("BillOwner")
  billsPaid             Bill[]               @relation("BillPayer")
  billsAuthored         Bill[]               @relation("BillAuthor")
  billsEdited           Bill[]               @relation("BillEditor")
  recurringBillsOwned   RecurringBill[]      @relation("RecurringBillOwner")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
}

model FamilyGroup {
  id             String          @id @default(uuid())
  name           String          @db.VarChar(100)
  members        User[]
  invite         Invite?
  categories     Category[]
  budgets        Budget[]
  bills          Bill[]
  recurringBills RecurringBill[]
  creditCards    CreditCard[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum PaymentMethod {
  CASH_OR_DEBIT
  CREDIT_CARD
}

enum CreditCardStatus {
  ACTIVE
  ARCHIVED
}

enum ResourceType {
  EXPENSE
  CATEGORY
}

enum BudgetTargetType {
  FAMILY
  MEMBER
  CATEGORY
}

enum BudgetLimitType {
  ABSOLUTE
  PERCENT
}

model Category {
  id             String          @id @default(uuid())
  groupId        String
  group          FamilyGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name           String          @db.VarChar(60)
  parentId       String?
  parent         Category?       @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children       Category[]      @relation("CategoryHierarchy")
  budgets        Budget[]
  bills          Bill[]
  recurringBills RecurringBill[]
  // normalizedName is a Postgres GENERATED ALWAYS column (declared in raw SQL,
  // collated pt_BR_ci_as). It backs the two partial unique indexes. The Prisma
  // client never reads or writes it — hence @ignore.
  normalizedName String          @ignore
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([groupId], map: "category_group_idx")
}

model IdempotencyKey {
  key          String       @id @db.VarChar(64)
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  resourceType ResourceType
  resourceId   String
  createdAt    DateTime     @default(now())

  @@index([userId], map: "idempotency_user_idx")
  @@index([createdAt], map: "idempotency_created_at_idx")
  @@index([resourceType, resourceId], map: "idempotency_resource_idx")
}

model Budget {
  id               String           @id @default(uuid())
  groupId          String
  group            FamilyGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  // Calendar month bucket — normalized to the first day of the month (YYYY-MM-01, UTC).
  month            DateTime         @db.Date
  targetType       BudgetTargetType
  targetMemberId   String?
  targetMember     User?            @relation("MemberBudget", fields: [targetMemberId], references: [id], onDelete: Cascade)
  targetCategoryId String?
  targetCategory   Category?        @relation(fields: [targetCategoryId], references: [id], onDelete: Cascade)
  limitType        BudgetLimitType
  // Exactly one of amountCents (ABSOLUTE) / percent (PERCENT) is set; enforced in the app layer.
  amountCents      Int?
  percent          Int?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // The three partial UNIQUE indexes ("one budget per group/month/target") are
  // declared in raw SQL in the migration (Prisma cannot express WHERE on @@unique).
  @@index([groupId, month], map: "budget_group_month_idx")
}

model Invite {
  id            String      @id @default(uuid())
  familyGroupId String      @unique
  familyGroup   FamilyGroup @relation(fields: [familyGroupId], references: [id])
  code          String      @unique @db.VarChar(8)
  expiresAt     DateTime
  createdAt     DateTime    @default(now())
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique @db.VarChar(128)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

// ─── Feature 010/011: Monthly Payment Tracker (Expense Consolidation) ────────

enum BillStatus {
  PENDING
  PAID
  CANCELLED
}

enum RecurrenceInterval {
  MONTHLY
  ANNUAL
}

enum RecurringBillStatus {
  ACTIVE
  PAUSED
  STOPPED
}

model RecurringBill {
  id                   String              @id @default(uuid())
  groupId              String
  group                FamilyGroup         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  description          String              @db.VarChar(200)
  expectedAmountCents  Int
  dueDay               Int
  interval             RecurrenceInterval
  startMonth           DateTime            @db.Date
  activeFromMonth      DateTime            @db.Date
  status               RecurringBillStatus @default(ACTIVE)
  categoryId           String?
  category             Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  ownerMemberId        String?
  ownerMember          User?               @relation("RecurringBillOwner", fields: [ownerMemberId], references: [id], onDelete: SetNull)
  deletedAt            DateTime?
  bills                Bill[]
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  @@index([groupId], map: "recurring_bill_group_idx")
}

// ─── Feature 012: Credit Card Management ─────────────────────────────────────

model CreditCard {
  id        String           @id @default(uuid())
  groupId   String
  group     FamilyGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name      String           @db.VarChar(60)
  // closingDay (dia de fechamento da fatura, 1–31) is informational/grouping
  // only (FR-001a) — it never governs settlement.
  closingDay Int
  status    CreditCardStatus @default(ACTIVE)
  bills     Bill[]
  // normalizedName is a Postgres GENERATED ALWAYS column (raw SQL, collated
  // pt_BR_ci_as) backing the partial unique index on active cards. @ignore so
  // the Prisma client never reads/writes it.
  normalizedName String        @ignore
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([groupId], map: "credit_card_group_idx")
}

model Bill {
  id                  String         @id @default(uuid())
  groupId             String
  group               FamilyGroup    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  description         String         @db.VarChar(200)
  expectedAmountCents Int
  dueDate             DateTime       @db.Date
  month               DateTime       @db.Date
  status              BillStatus     @default(PENDING)
  categoryId          String?
  category            Category?      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  ownerMemberId       String?
  ownerMember         User?          @relation("BillOwner", fields: [ownerMemberId], references: [id], onDelete: SetNull)
  recurringBillId     String?
  recurringBill       RecurringBill? @relation(fields: [recurringBillId], references: [id], onDelete: Restrict)
  // Payment fields — all NULL ↔ status ≠ PAID; all NOT NULL ↔ status = PAID
  paidDate            DateTime?      @db.Date
  actualAmountCents   Int?
  paidByMemberId      String?
  paidByMember        User?          @relation("BillPayer", fields: [paidByMemberId], references: [id], onDelete: SetNull)
  paymentMethod       PaymentMethod?
  // Authorship (FR-004, feature 011): nullable so legacy bills without an author remain valid
  createdById         String?
  createdBy           User?          @relation("BillAuthor", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById         String?
  updatedBy           User?          @relation("BillEditor", fields: [updatedById], references: [id], onDelete: SetNull)
  // Feature 012: credit card link (purchase OR fatura role), fatura marker, and
  // snapshot settlement self-link (which fatura settled this purchase).
  creditCardId        String?
  creditCard          CreditCard?    @relation(fields: [creditCardId], references: [id], onDelete: Restrict)
  isFatura            Boolean        @default(false)
  settledByFaturaId   String?
  settledByFatura     Bill?          @relation("FaturaSettlement", fields: [settledByFaturaId], references: [id], onDelete: SetNull)
  settledCharges      Bill[]         @relation("FaturaSettlement")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Partial unique index (recurringBillId, month) WHERE recurringBillId IS NOT NULL
  // is declared as raw SQL in the migration — idempotency guarantee for the scheduler.
  // Partial unique (creditCardId) WHERE isFatura AND status='PENDING' (one pending
  // fatura per card, FR-012a) is also raw SQL in the 012 migration.
  @@index([groupId, month], map: "bill_group_month_idx")
  @@index([groupId, paidDate], map: "bill_group_paiddate_idx")
  @@index([creditCardId], map: "bill_credit_card_idx")
}
